<Window x:Class="DerbyApp.Windows.ProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DerbyApp.Windows"
        mc:Ignorable="d"
        Title="ProgressWindow" Height="120" Width="300">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
            <RowDefinition Height="1*"/>
        </Grid.RowDefinitions>
        <Label>Copying Database...</Label>
        <ProgressBar Grid.Row="1" x:Name="TableProgressBarControl"
                     Minimum="0"
                     Maximum="100"
                     Height="25"
                     Width="250"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"/>
        <ProgressBar Grid.Row="2" x:Name="ProgressBarControl"
                     Minimum="0"
                     Maximum="100"
                     Height="25"
                     Width="250"
                     VerticalAlignment="Center"
                     HorizontalAlignment="Center"/>
    </Grid>
</Window>
